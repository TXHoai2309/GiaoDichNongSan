<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SellerFormSectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">22dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:textColor">#4A423D</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SellerFormInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:background">@drawable/bg_edittext</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textColor">#4A423D</item>
        <item name="android:textColorHint">#9A9089</item>
        <item name="android:textSize">15sp</item>
        <item name="android:singleLine">true</item>
    </style>
</resources>
