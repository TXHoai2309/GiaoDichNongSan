<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ===== HEADER SHOP ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#fff"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgShop"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_shop" />

            <LinearLayout
                android:layout_marginStart="12dp"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvTenShop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nông sản xanh"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvDanhGia"
                    android:text="⭐ 4.8 | Shop yêu thích"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#666"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ===== THỐNG KÊ ===== -->
        <LinearLayout
            android:layout_marginTop="10dp"
            android:background="#fff"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <TextView
                android:id="@+id/tvSanPham"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="256\nSản phẩm"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvFollower"
                android:layout_weight="1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1.2k\nTheo dõi"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvThamGia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2 năm\nTham gia"
                android:gravity="center"/>
        </LinearLayout>

        <!-- ===== THÔNG TIN SHOP ===== -->
        <LinearLayout
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:background="#fff"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thông tin shop"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMoTa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chuyên cung cấp nông sản sạch"/>

            <TextView
                android:id="@+id/tvDiaChi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="📍 Hà Nội"/>

            <TextView
                android:id="@+id/tvPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="📞 0987xxxx"/>
        </LinearLayout>

        <!-- ===== BUTTON ===== -->
        <LinearLayout
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnFollow"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Theo dõi"
                android:backgroundTint="#7B61FF"
                android:textColor="#fff"/>

            <Button
                android:id="@+id/btnChat"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Chat"
                android:layout_marginStart="8dp"
                android:backgroundTint="#4CAF50"
                android:textColor="#fff"/>
        </LinearLayout>

        <!-- ===== DANH SÁCH SẢN PHẨM ===== -->
        <TextView
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sản phẩm đang bán"
            android:textStyle="bold"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSanPhamShop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>