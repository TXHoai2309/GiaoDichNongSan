<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1EC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btnBackQuanLyShop"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:contentDescription="Quay lại"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#4A423D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Quản lý bán hàng"
                android:textColor="#4A423D"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnMenuQuanLyShop"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="Menu"
                android:src="@android:drawable/ic_menu_more"
                app:tint="#4A423D" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD3CC" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="#FFF8F4"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="#E9E3DF"
                    android:contentDescription="Shop"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="#7A6F67" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTenShop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Đang tải cửa hàng..."
                        android:textColor="#4A423D"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTrangThaiShop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Đã phê duyệt"
                        android:textColor="#68A25A"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvMoTaShop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Mô tả gian hàng"
                android:textColor="#6E625B"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSoSanPham"
                    style="@style/ShopStatText"
                    android:text="0\nSản phẩm" />

                <TextView
                    android:id="@+id/tvDonChoXuLy"
                    style="@style/ShopStatText"
                    android:text="0\nChờ xử lý" />

                <TextView
                    android:id="@+id/tvDoanhThu"
                    style="@style/ShopStatText"
                    android:text="0đ\nDoanh thu" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:text="Công cụ quản lý"
            android:textColor="#4A423D"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="#FFF8F4"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/itemThongTinShop"
                style="@style/ShopMenuItem">
                <TextView
                    style="@style/ShopMenuTitle"
                    android:text="Thông tin cửa hàng" />
            </LinearLayout>

            <View style="@style/ShopDivider" />

            <LinearLayout
                android:id="@+id/itemQuanLySanPham"
                style="@style/ShopMenuItem">
                <TextView
                    style="@style/ShopMenuTitle"
                    android:text="Quản lý sản phẩm" />
            </LinearLayout>

            <View style="@style/ShopDivider" />

            <LinearLayout
                android:id="@+id/itemQuanLyDonHang"
                style="@style/ShopMenuItem">
                <TextView
                    style="@style/ShopMenuTitle"
                    android:text="Quản lý đơn hàng" />
            </LinearLayout>

            <View style="@style/ShopDivider" />

            <LinearLayout
                android:id="@+id/itemThongKeDoanhThu"
                style="@style/ShopMenuItem">
                <TextView
                    style="@style/ShopMenuTitle"
                    android:text="Thống kê doanh thu" />
            </LinearLayout>

            <View style="@style/ShopDivider" />

            <LinearLayout
                android:id="@+id/itemCaiDatShop"
                style="@style/ShopMenuItem">
                <TextView
                    style="@style/ShopMenuTitle"
                    android:text="Cài đặt cửa hàng" />
            </LinearLayout>

            <View style="@style/ShopDivider" />

            <LinearLayout
                android:id="@+id/itemTrungTamTroGiup"
                style="@style/ShopMenuItem">
                <TextView
                    style="@style/ShopMenuTitle"
                    android:text="Trung tâm trợ giúp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCanhBao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:gravity="center"
            android:text="Không tìm thấy cửa hàng đã được phê duyệt"
            android:textColor="#8A7F77"
            android:textSize="15sp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
