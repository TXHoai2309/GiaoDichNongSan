<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1EC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btnBackDangKyBanHang"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:contentDescription="Quay lại"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#4A423D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Đăng ký bán hàng"
                android:textColor="#4A423D"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnMenuDangKyBanHang"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="Menu"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="#4A423D" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD3CC" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thông tin người bán"
                android:textColor="#4A423D"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cung cấp thông tin chính xác để quản trị viên xét duyệt gian hàng."
                android:textColor="#6E625B"
                android:textSize="14sp" />

            <TextView
                style="@style/SellerFormSectionTitle"
                android:text="1. Thông tin cá nhân" />

            <EditText
                android:id="@+id/edtHoTen"
                style="@style/SellerFormInput"
                android:hint="Họ và tên"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/edtSoDienThoai"
                style="@style/SellerFormInput"
                android:hint="Số điện thoại"
                android:inputType="phone" />

            <EditText
                android:id="@+id/edtEmail"
                style="@style/SellerFormInput"
                android:hint="Email"
                android:inputType="textEmailAddress" />

            <EditText
                android:id="@+id/edtCCCD"
                style="@style/SellerFormInput"
                android:hint="Số CCCD"
                android:inputType="number" />

            <EditText
                android:id="@+id/edtDiaChiCuTru"
                style="@style/SellerFormInput"
                android:hint="Địa chỉ cư trú"
                android:inputType="textPostalAddress" />

            <TextView
                style="@style/SellerFormSectionTitle"
                android:text="2. Thông tin gian hàng" />

            <EditText
                android:id="@+id/edtTenGianHang"
                style="@style/SellerFormInput"
                android:hint="Tên gian hàng"
                android:inputType="textCapWords" />

            <EditText
                android:id="@+id/edtMoTaGianHang"
                style="@style/SellerFormInput"
                android:hint="Mô tả gian hàng"
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="86dp" />

            <EditText
                android:id="@+id/edtDiaChiKinhDoanh"
                style="@style/SellerFormInput"
                android:hint="Địa chỉ sản xuất / kinh doanh"
                android:inputType="textPostalAddress" />

            <EditText
                android:id="@+id/edtLoaiNongSan"
                style="@style/SellerFormInput"
                android:hint="Loại nông sản kinh doanh"
                android:inputType="textCapSentences" />

            <EditText
                android:id="@+id/edtNguonGocSanPham"
                style="@style/SellerFormInput"
                android:hint="Nguồn gốc sản phẩm"
                android:inputType="textCapSentences" />

            <TextView
                style="@style/SellerFormSectionTitle"
                android:text="3. Giấy chứng nhận" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgGiayATTP"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="#E9E3DF"
                        android:contentDescription="Ảnh chứng nhận ATTP"
                        android:padding="20dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_camera" />

                    <Button
                        android:id="@+id/btnChonAnhATTP"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#D9D2CD"
                        android:text="Chọn ATTP"
                        android:textAllCaps="false"
                        android:textColor="#4A423D" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgGiayVietGap"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="#E9E3DF"
                        android:contentDescription="Ảnh chứng nhận VietGAP"
                        android:padding="20dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_camera" />

                    <Button
                        android:id="@+id/btnChonAnhVietGap"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#D9D2CD"
                        android:text="Chọn VietGAP"
                        android:textAllCaps="false"
                        android:textColor="#4A423D" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/SellerFormSectionTitle"
                android:text="4. Thông tin thanh toán" />

            <EditText
                android:id="@+id/edtSoTaiKhoan"
                style="@style/SellerFormInput"
                android:hint="Số tài khoản ngân hàng"
                android:inputType="number" />

            <EditText
                android:id="@+id/edtTenChuTaiKhoan"
                style="@style/SellerFormInput"
                android:hint="Tên chủ tài khoản"
                android:inputType="textPersonName" />

            <LinearLayout
                android:id="@+id/btnGuiYeuCau"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvGuiYeuCau"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gửi yêu cầu xét duyệt"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
