<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1EC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btnBackDangKyBanHang"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:contentDescription="Quay lại"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#4A423D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Đăng ký bán hàng"
                android:textColor="#4A423D"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnMenuDangKyBanHang"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="Menu"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#4A423D" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#EFE6E1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1. Thông tin cá nhân"
                    android:textColor="#4A423D"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF8F4"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/edtHoTen"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Họ và tên"
                    android:inputType="textPersonName"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <EditText
                    android:id="@+id/edtSoDienThoai"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Số điện thoại"
                    android:inputType="phone"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <EditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Email (nếu có)"
                    android:inputType="textEmailAddress"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <EditText
                    android:id="@+id/edtCCCD"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Số CCCD"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <EditText
                    android:id="@+id/edtDiaChiCuTru"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Địa chỉ cư trú"
                    android:inputType="textPostalAddress"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="#EFE6E1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2. Thông tin gian hàng"
                    android:textColor="#4A423D"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF8F4"
                android:orientation="vertical"
                android:paddingBottom="10dp">

                <EditText
                    android:id="@+id/edtTenGianHang"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Tên gian hàng"
                    android:inputType="textCapWords"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <EditText
                    android:id="@+id/edtMoTaGianHang"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_search"
                    android:hint="Mô tả gian hàng (giới thiệu ngắn)"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <EditText
                    android:id="@+id/edtDiaChiKinhDoanh"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Địa chỉ sản xuất / kinh doanh"
                    android:inputType="textPostalAddress"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <EditText
                    android:id="@+id/edtLoaiNongSan"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Loại nông sản kinh doanh (rau, củ, quả...)"
                    android:inputType="textCapSentences"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <EditText
                    android:id="@+id/edtNguonGocSanPham"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Nguồn gốc sản phẩm"
                    android:inputType="textCapSentences"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Giấy chứng nhận an toàn thực phẩm"
                    android:textColor="#4A423D"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingStart="12dp"
                    android:paddingTop="10dp" />

                <ImageView
                    android:id="@+id/imgGiayATTP"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="6dp"
                    android:background="#E9E3DF"
                    android:padding="12dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera" />

                <Button
                    android:id="@+id/btnChonAnhATTP"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="6dp"
                    android:backgroundTint="#D9D2CD"
                    android:text="Chọn ảnh ATTP"
                    android:textAllCaps="false"
                    android:textColor="#4A423D" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Giấy chứng nhận VietGAP / hữu cơ"
                    android:textColor="#4A423D"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingStart="12dp"
                    android:paddingTop="10dp" />

                <ImageView
                    android:id="@+id/imgGiayVietGap"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="6dp"
                    android:background="#E9E3DF"
                    android:padding="12dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera" />

                <Button
                    android:id="@+id/btnChonAnhVietGap"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="6dp"
                    android:backgroundTint="#D9D2CD"
                    android:text="Chọn ảnh VietGAP"
                    android:textAllCaps="false"
                    android:textColor="#4A423D" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="#EFE6E1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3. Thông tin thanh toán"
                    android:textColor="#4A423D"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF8F4"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/edtSoTaiKhoan"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Số tài khoản ngân hàng"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />

                <EditText
                    android:id="@+id/edtTenChuTaiKhoan"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:hint="Tên chủ tài khoản"
                    android:inputType="textPersonName"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#4A423D"
                    android:textColorHint="#8A7F77" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnGuiYeuCau"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_search"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gửi yêu cầu"
                    android:textColor="#4A423D"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>