<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ① TRẠNG THÁI ĐƠN HÀNG -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRẠNG THÁI ĐƠN HÀNG"
                    android:textSize="12sp" android:textColor="#AAAAAA"/>

                <TextView android:id="@+id/tvTrangThai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Đang giao hàng"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFA000"/>

                <TextView android:id="@+id/tvNgayDat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Đặt lúc: 01/05/2026"
                    android:textSize="13sp"
                    android:textColor="#757575"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ② THÔNG TIN NGƯỜI MUA -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 THÔNG TIN GIAO HÀNG"
                    android:textSize="12sp" android:textColor="#AAAAAA"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_accountto"
                        android:layout_marginEnd="10dp"/>

                    <TextView android:id="@+id/tvTenNguoiMua"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nguyễn Văn A"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>

                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_phone"
                        android:layout_marginEnd="10dp"/>

                    <TextView android:id="@+id/tvSdt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0987654321"
                        android:textSize="14sp"
                        android:textColor="#424242"/>

                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginTop="8dp">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_location"
                        android:layout_marginEnd="10dp"/>

                    <TextView android:id="@+id/tvDiaChi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="123 Đường ABC, Quận 1, TP.HCM"
                        android:textSize="14sp"
                        android:textColor="#424242"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ③ DANH SÁCH SẢN PHẨM -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛍 SẢN PHẨM ĐÃ ĐẶT"
                    android:textSize="12sp" android:textColor="#AAAAAA"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSanPham"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ④ TỔNG TIỀN -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Tổng tiền hàng"
                        android:textSize="14sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvTien"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textColor="#212121"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#EEEEEE" android:layout_marginVertical="10dp"/>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Thành tiền"
                        android:textSize="16sp" android:textStyle="bold" android:textColor="#212121"/>
                    <TextView android:id="@+id/tvTongTien"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="18sp" android:textStyle="bold" android:textColor="#E53935"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ⑤ NÚT HÀNH ĐỘNG -->
        <Button
            android:id="@+id/btnCapNhatTrangThai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Cập nhật trạng thái"
            android:backgroundTint="#4CAF50"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnHuyDon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Huỷ đơn hàng"
            android:backgroundTint="#F44336"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>