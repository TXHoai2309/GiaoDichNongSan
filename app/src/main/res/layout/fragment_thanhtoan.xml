<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1EC"
    android:orientation="vertical">

    <!-- ===== SCROLL CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- HEADER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trang mua hàng"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="10dp"/>

            <!-- THÔNG TIN -->
            <LinearLayout
                android:id="@+id/layoutThongTin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_border"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvTenNguoiNhan"
                    android:text="Nguyễn Văn A (0987654321)"
                    android:textStyle="bold"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvDiaChi"
                    android:text="123 Đường ABC, TP.HCM"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvGhiChu"
                    android:text="Ghi chú: Không có"
                    android:textSize="12sp"
                    android:textColor="#777"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- SẢN PHẨM -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sản phẩm"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvThanhToan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- VẬN CHUYỂN -->
            <LinearLayout
                android:id="@+id/layoutVanChuyen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_border"
                android:padding="14dp"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_height="wrap_content"
                    android:id="@+id/tvTenVanChuyen"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Vận chuyển nhanh"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvPhiShip"
                    android:text="30.000đ"
                    android:textColor="#FF5722"/>

            </LinearLayout>

            <!-- THANH TOÁN -->
            <LinearLayout
                android:id="@+id/layoutThanhToan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_border"
                android:padding="14dp"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_height="wrap_content"
                    android:id="@+id/tvTenThanhToan"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Thanh toán khi nhận hàng"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvMoTaThanhToan"
                    android:text="COD"
                    android:textColor="#FF5722"/>

            </LinearLayout>

            <!-- CHI TIẾT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_border"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chi tiết thanh toán"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvDanhSachSP"
                    android:text="Súp lơ x1"
                    android:textSize="13sp"
                    android:textColor="#444"/>
                <LinearLayout
                    android:id="@+id/layoutPTTT"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                  >

                    <!-- LABEL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phương thức thanh toán:"
                        android:textColor="#666"/>

                    <!-- VALUE -->
                    <TextView
                        android:id="@+id/tvMoTaThanhToanChiTiet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" COD"
                        android:textStyle="bold"
                        android:textColor="#FF5722"
                        android:layout_marginStart="6dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvTienHang"
                    android:text="Tiền hàng: 0đ"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvTong"
                    android:text="Tổng thanh toán: 0đ"
                    android:textStyle="bold"
                    android:textColor="#FF5722"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 🔥 BUTTON DƯỚI CÙNG -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnDatHang"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_margin="12dp"
        android:text="ĐẶT HÀNG"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/bg_button"
        android:backgroundTint="@null"/>

</LinearLayout>