<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1EC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:contentDescription="Quay lại"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#4A423D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Cá nhân"
                android:textColor="#4A423D"
                android:textSize="28sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD3CC" />

        <!-- Thông tin user -->
        <LinearLayout
            android:id="@+id/layoutUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="Avatar"
                android:src="@android:drawable/sym_def_app_icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nguyễn Văn A"
                    android:textColor="#4A423D"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0123 456 789"
                    android:textColor="#6E625B"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/tvDangNhapTaiKhoan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Đăng nhập"
                    android:textColor="#68A25A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDangKyTaiKhoan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Đăng ký tài khoản"
                    android:textColor="#6E625B"
                    android:textSize="15sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Chi tiết"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7F77" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <!-- Thông tin cá nhân -->
        <LinearLayout
            android:id="@+id/itemThongTinCaNhan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Thông tin cá nhân"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#7A6F67" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Thông tin cá nhân"
                android:textColor="#4A423D"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Đi tới"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7F77" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <!-- Đổi mật khẩu -->
        <LinearLayout
            android:id="@+id/itemDoiMatKhau"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Đổi mật khẩu"
                android:src="@android:drawable/ic_lock_lock"
                app:tint="#7A6F67" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Đổi mật khẩu"
                android:textColor="#4A423D"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Đi tới"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7F77" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <!-- Đăng ký bán hàng -->
        <LinearLayout
            android:id="@+id/itemDangKyBanHang"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Đăng ký bán hàng"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#7A6F67" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Đăng ký bán hàng"
                android:textColor="#4A423D"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Đi tới"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7F77" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <!-- Quản lý cửa hàng -->
        <LinearLayout
            android:id="@+id/itemQuanLyCuaHang"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Quản lý cửa hàng"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#7A6F67" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Quản lý cửa hàng"
                android:textColor="#4A423D"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Đi tới"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7F77" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <!-- Giới thiệu -->
        <LinearLayout
            android:id="@+id/itemGioiThieu"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Giới thiệu"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="#7A6F67" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Giới thiệu về chúng tôi"
                android:textColor="#4A423D"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Đi tới"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7F77" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <!-- Điều khoản -->
        <LinearLayout
            android:id="@+id/itemDieuKhoan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Điều khoản"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#7A6F67" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Điều khoản và chính sách"
                android:textColor="#4A423D"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Đi tới"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7F77" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <!-- Trợ giúp -->
        <LinearLayout
            android:id="@+id/itemTroGiup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Trung tâm trợ giúp"
                android:src="@android:drawable/ic_menu_help"
                app:tint="#7A6F67" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Trung tâm trợ giúp"
                android:textColor="#4A423D"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Đi tới"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7F77" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <!-- Switch 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tắt cảm ứng hỗ trợ"
                android:textColor="#4A423D"
                android:textSize="17sp" />

            <Switch
                android:id="@+id/switchCamUng"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2D8D1" />

        <!-- Switch 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFF8F4"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tắt tự động chỉnh độ sáng"
                android:textColor="#4A423D"
                android:textSize="17sp" />

            <Switch
                android:id="@+id/switchDoSang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:background="#F8F1EC" />
        <Button
            android:id="@+id/btnLogoutUser"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Đăng xuất"
            android:layout_margin="16dp"
            android:backgroundTint="#E53935"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
    </LinearLayout>

</ScrollView>